# ===========================================
# Phantom — Environment Variables
# ===========================================
# Copy this file to .env and fill in your keys.
# NEVER commit .env to version control.

# --- Bright Data ---
BRIGHT_DATA_API_KEY=
BRIGHT_DATA_SERP_ZONE=serp
BRIGHT_DATA_WEB_SCRAPER_ZONE=web_scraper
BRIGHT_DATA_WEB_UNLOCKER_ZONE=web_unlocker

# --- LLM Provider (OpenAI) ---
OPENAI_API_KEY=

# --- Backend ---
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# --- Rate Limiting ---
RATE_LIMIT=5/minute
